# Servidor
PORT=5000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173
TRUST_PROXY=0

# MongoDB
MONGODB_URI=mongodb+srv://usuario:senha@cluster/banco

# Autenticacao
JWT_SECRET=substitua-por-um-segredo-longo-e-aleatorio
JWT_ISSUER=boilerplate-api
JWT_AUDIENCE=boilerplate-admin
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
SESSION_IDLE_TTL_MINUTES=60
AUTH_COOKIE_SECURE=false

# Criacao inicial de administrador (usado apenas por npm run admin:create)
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Cloudinary (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
